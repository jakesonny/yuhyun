# Input files
# Runtime tracking settings file (preferred for end-user editable config)
AGENT_SETTINGS_PATH=./settings.json

# Env fallback (used only when AGENT_SETTINGS_PATH file is missing)
# Multi-folder mode (comma-separated absolute/relative paths) takes priority:
# AGENT_WATCH_DIRS=./sample-data,./sample-data-2
AGENT_WATCH_DIRS=
# Explicit files mode (comma-separated file paths) has highest priority:
# AGENT_INCLUDE_FILES=E:\measure\A.txt,E:\measure\sub\B.txt
AGENT_INCLUDE_FILES=
AGENT_WATCH_DIR=./sample-data
AGENT_FILE_EXTENSION=.txt

# Agent local queue
AGENT_DB_PATH=./agent-queue.db

# Backend/identity fallback (settings.json 없을 때만 사용 — Windows는 agent-config.exe로 settings.json 생성 권장)
BACKEND_INGEST_URL=https://yuhyeon.onrender.com/api/ingest
AGENT_API_KEY=
AGENT_HMAC_SECRET=
# 수집 이벤트에 실리는 "현장/프로젝트" 구분용 문자열 → DB raw_logs.site_id 로 저장됨.
# 백엔드는 이 값으로 허용 여부를 검사하지 않음(검사는 AGENT_API_KEY·HMAC·선택적 ALLOWED_AGENT_ID).
AGENT_SITE_ID=site-001
# 이 PC(에이전트 인스턴스)를 가리키는 ID → DB raw_logs.agent_id 및 백엔드 ALLOWED_AGENT_ID(설정 시)와 비교됨.
AGENT_ID=field-pc-001

# Runtime tunings
AGENT_SCAN_INTERVAL_MS=2000
AGENT_SEND_INTERVAL_MS=2000
AGENT_SEND_BATCH_SIZE=100
AGENT_MAX_BACKOFF_MS=300000
AGENT_HEALTH_FILE_PATH=./agent-health.json
