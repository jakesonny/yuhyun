# Input files
# Multi-folder mode (comma-separated absolute/relative paths) takes priority:
# AGENT_WATCH_DIRS=./sample-data,./sample-data-2
AGENT_WATCH_DIRS=
# Explicit files mode (comma-separated file paths) has highest priority:
# AGENT_INCLUDE_FILES=E:\measure\A.txt,E:\measure\sub\B.txt
AGENT_INCLUDE_FILES=
AGENT_WATCH_DIR=./sample-data
AGENT_FILE_EXTENSION=.txt

# Agent local queue
AGENT_DB_PATH=./agent-queue.db

# Backend ingest API
BACKEND_INGEST_URL=http://localhost:3000/api/ingest
AGENT_API_KEY=replace-with-backend-key
AGENT_HMAC_SECRET=replace-with-backend-secret

# Agent identity
AGENT_SITE_ID=site-001
AGENT_ID=field-pc-001

# Runtime tunings
AGENT_SCAN_INTERVAL_MS=2000
AGENT_SEND_INTERVAL_MS=2000
AGENT_SEND_BATCH_SIZE=100
AGENT_MAX_BACKOFF_MS=300000
AGENT_HEALTH_FILE_PATH=./agent-health.json
