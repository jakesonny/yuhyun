PORT=3000

# Agent -> Backend auth
AGENT_API_KEY=replace-with-strong-api-key
AGENT_HMAC_SECRET=replace-with-strong-hmac-secret
# 비우면 agentId 제한 없음. 값이 있으면 payload.agentId와 일치할 때만 허용(siteId는 검사 안 함).
ALLOWED_AGENT_ID=field-pc-001

# Postgres mode (recommended on Render)
# Use Render "External Database URL" value.
DATABASE_URL=replace-with-render-external-database-url
PGSSL_DISABLE=false

# SQLite fallback (used only when DATABASE_URL is empty)
INGEST_DB_PATH=./data/ingest.db
