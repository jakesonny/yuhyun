PORT=3000

# Agent -> Backend auth
AGENT_API_KEY=replace-with-strong-api-key
AGENT_HMAC_SECRET=replace-with-strong-hmac-secret

# Optional: allow only one agent id at first
ALLOWED_AGENT_ID=field-pc-001

# Storage mode:
# - If DATABASE_URL exists -> Postgres mode
# - Else -> SQLite fallback mode
DATABASE_URL=
PGSSL_DISABLE=false

# SQLite fallback path (used only when DATABASE_URL is empty)
INGEST_DB_PATH=./data/ingest.db
